# Email Provider Settings
# If these are set, they will override Firestore global communication settings

RESEND_API_KEY=
BREVO_API_KEY=
SENDGRID_API_KEY=
SENDER_EMAIL=
SENDER_NAME=
DEFAULT_EMAIL_PROVIDER=resend

# Optional: Google / Gmail direct method
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Firebase Configuration (Optional: overrides firebase-applet-config.json)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=
